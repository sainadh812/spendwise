# =============================================================================
# DATABASE
# =============================================================================
# Vercel Postgres connection string (or any PostgreSQL URL)
# For local dev, use: postgresql://postgres:postgres@localhost:5432/expense_tracker
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# =============================================================================
# AUTHENTICATION
# =============================================================================
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-random-secret-here"

# The password to access your dashboard (pick something strong for production)
AUTH_PASSWORD="your-secure-password"

# =============================================================================
# AI - Gemini (Vercel AI SDK)
# =============================================================================
# Get your API key at: https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY="your-gemini-api-key"

# =============================================================================
# GMAIL API (for email parsing)
# =============================================================================
# Create OAuth 2.0 credentials for Gmail API access.
# Use https://developers.google.com/oauthplayground to get a refresh token.
# Enable the Gmail API in Google Cloud Console.
GMAIL_CLIENT_ID="your-gmail-oauth-client-id"
GMAIL_CLIENT_SECRET="your-gmail-oauth-client-secret"
GMAIL_REFRESH_TOKEN="your-gmail-refresh-token"

# Gmail search query. Leave blank to use the built-in query that targets:
#   - HDFC Bank alerts (from:alerts@hdfcbank.net OR from:alerts@hdfcbank.bank.in)
#   - IDFC FIRST Bank alerts (from:delivery.idfcfirstbank.com subject:"Debit Alert")
# Set this only if you want to override with a custom query.
# GMAIL_SEARCH_QUERY=""

# =============================================================================
# CRON SECURITY
# =============================================================================
# Secret to protect the /api/process-emails endpoint
# Generate with: openssl rand -hex 32
CRON_SECRET="your-cron-secret"
