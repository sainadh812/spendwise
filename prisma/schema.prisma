generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Category {
  id        String     @id @default(uuid())
  name      String
  parentId  String?
  parent    Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryHierarchy")

  transactionsAsCategory    Transaction[] @relation("TransactionCategory")
  transactionsAsSubcategory Transaction[] @relation("TransactionSubcategory")

  @@unique([name, parentId])
}

model Transaction {
  id               String    @id @default(uuid())
  amount           Float
  merchant         String
  date             DateTime
  category         String
  categoryId       String?
  subcategoryId    String?
  categoryRef      Category? @relation("TransactionCategory", fields: [categoryId], references: [id])
  subcategoryRef   Category? @relation("TransactionSubcategory", fields: [subcategoryId], references: [id])
  is_cc_payment    Boolean   @default(false)
  confidence_score Float
  needs_review     Boolean   @default(true)
  email_message_id String?   @unique
  remarks          String?
  source           String    @default("email")
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  @@index([amount, merchant, date], name: "idx_dedup")
  @@index([categoryId])
  @@index([subcategoryId])
}

model Budget {
  id          String   @id @default(uuid())
  amount      Float
  start_month Int
  start_year  Int
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@unique([start_month, start_year])
  @@index([start_year, start_month])
}

model SkippedEmail {
  id               String   @id @default(uuid())
  email_message_id String   @unique
  subject          String
  sender           String
  body_snippet     String
  ai_reason        String?
  dismissed        Boolean  @default(false)
  created_at       DateTime @default(now())
}

model Insight {
  id                     String   @id @default(uuid())
  period_type            String
  period_key             String
  month                  Int?
  year                   Int
  stats                  Json
  summary                String
  trends                 Json
  anomalies              Json
  suggestions            Json
  tx_count_at_generation Int
  tx_latest_at_generation DateTime
  model                  String   @default("gemini-2.5-pro")
  created_at             DateTime @default(now())
  updated_at             DateTime @updatedAt

  @@unique([period_type, period_key])
  @@index([year, month])
}
